# .env file for Messier_Objects script
# John Downing Observatory
LATITUDE=33.242014          # Latitude in decimal degrees
LONGITUDE=-116.977853       # Longitude in decimal degrees (West is negative)
ALTITUDE=500                # Altitude in meters above sea level
TIMEZONE=America/Los_Angeles# IANA Time Zone Name (e.g., America/Chicago, America/Denver, America/New_York)
ALTITUDE_LIMIT=30           # Minimum altitude in degrees for visibility calculations
