# .env file for Messier_Objects script
# Utah Desert Remote Observatory
LATITUDE=37.7378            # Latitude in decimal degrees
LONGITUDE=-113.6975         # Longitude in decimal degrees (West is negative)
ALTITUDE=1570               # Altitude in meters above sea level
TIMEZONE=America/Denver     # IANA Time Zone Name (e.g., America/Chicago, America/Denver, America/New_York)
ALTITUDE_LIMIT=30           # Minimum altitude in degrees for visibility calculations
