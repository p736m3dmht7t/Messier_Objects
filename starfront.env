# .env file for Messier_Objects script
# SFRO Starfront Remote Observatory
LATITUDE=31.5473            # Latitude in decimal degrees
LONGITUDE=-99.3827          # Longitude in decimal degrees (West is negative)
ALTITUDE=446                # Altitude in meters above sea level
TIMEZONE=America/Chicago    # IANA Time Zone Name (e.g., America/Chicago, America/Denver, America/New_York)
ALTITUDE_LIMIT=30           # Minimum altitude in degrees for visibility calculations
